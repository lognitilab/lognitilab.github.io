@techreport{rai2026developing,
  abbr={BTech},
  title={Graph Neural Network-Based Tour Length Estimation for the Travelling Salesman Problem},
  author={Rai, Abshishek and Pahwa, Anmol},
  abstract={Tour length estimation plays an important role in logistics planning, where fast approximations are needed across large numbers of scenarios without running a full optimization each time. Classical Continuous Approximation (CA) methods, such as the Beardwood-Halton-Hammersley (BHH) formula, provide analytical estimates but assume customers are uniformly distributed, an assumption that often breaks down in real delivery networks where demand clusters spatially around dense areas. This project explores whether Graph Neural Networks can learn to predict TSP and VRP tour lengths more accurately than classical formulas, particularly on non-uniform and clustered customer distributions. By representing each problem instance as a graph, where nodes are customer locations and edges capture spatial relationships, a GNN can potentially learn structural patterns that fixed analytical formulas cannot express. The model will be trained on synthetically generated instances using optimal tour lengths from an exact solver as ground truth. Prediction accuracy will be evaluated against the BHH formula and a standard feedforward neural network baseline, across both uniform and clustered distributions, to assess where and by how much the graph-based approach improves on existing methods.},
  institution={Jun 2026},
  year={2026}
}

@techreport{nemalipuri2026price,
  abbr={BTech},
  title={An Economic Analysis of Wage Elasticity and Labor Mobility among Gig Workers},
  author={Nemalipuri, Akshith and Pahwa, Anmol},
  abstract={This study explores the impact of platform remuneration on the labor supply of Gig Workers in the Quick Commerce sector of Chennai. The analysis shifts its focus from traditional qualitative evaluations to include an economic perspective, where changes in dynamic compensation, which includes base salary, premium rates during peak hours, and milestone rewards, either directly or indirectly determine the level of driver loyalty and working hours on the platform and inter-industry labor mobility, both internal and external. Through a detailed survey conducted in important commercial districts of Chennai, the project will gather gross incentives provided by the platforms along with the operating costs to derive net salaries. The collected information will help in estimating econometric models for labor supply, allowing us to determine the precise wage elasticity of the crowdsourced delivery workers. This project is expected to reveal the economic boundaries of gig workers’ behavior.},
  institution={Jun 2026},
  year={2026}
}

