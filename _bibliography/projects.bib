@techreport{pahwa2027optimizing,
  abbr={PostDoc},
  title={Optimizing Crowdsourced Delivery Systems for Perishable Goods},
  author={Pahwa, Anmol},
  abstract={Perishable goods delivery presents unique logistical challenges where product quality deteriorates rapidly during transport, requiring precise timing and temperature control to maintain consumer satisfaction. These complexities have been amplified by quick-commerce platforms delivering groceries and meals within 15–30 minute windows, creating demands for algorithmic solutions that handle workforce volatility and product degradation constraints. Platforms face inefficiencies due to unpredictable agent availability and inadequate routing optimization that fails to account for time-sensitive quality requirements. This research develops an integrated framework combining machine learning (ML) and microeconomic modeling to optimize crowdsourced delivery systems for perishable goods, addressing gaps where traditional logistics models prove inadequate in dynamic marketplace environments. The approach represents a shift from isolated optimization domains toward comprehensive algorithmic integration that addresses supply uncertainty and demand variability in crowdsourced networks. The supply prediction module employs ensemble ML algorithms to forecast delivery agent participation patterns by analyzing behavioral economics factors, including incentive structures, opportunity costs, and external market conditions. The demand forecasting component utilizes recurrent neural networks with attention mechanisms to capture temporal dependencies in consumer purchasing patterns, incorporating lead time preferences, price sensitivity, and quality degradation expectations for perishable goods categories. The framework operates through integrated data pipelines where real-time demand forecasting triggers supply prediction algorithms, which feed into the routing optimization engine. When orders are placed, demand updates inform supply availability assessments within delivery time windows, converging into route assignments that minimize spoilage while maximizing stakeholder satisfaction. The core innovation integrates economic constraints into vehicle routing optimization algorithms, ensuring route planning optimizes both operational efficiency and market-driven factors, including dynamic pricing and agent compensation. The routing engine considers product shelf life, temperature requirements, and delivery urgency to minimize spoilage while maximizing satisfaction across all stakeholders. This interdisciplinary approach bridges economic theory, machine learning, and operations research to advance knowledge in crowdsourced delivery optimization while demonstrating measurable improvements in delivery efficiency, cost effectiveness, and stakeholder satisfaction for perishable goods logistics.},
  institution={Jul 2027},
  year={2027}
}

@techreport{pahwa2027modelling,
  abbr={PostDoc},
  title={Modelling the Spatial Structure of Service Catchment Areas in Q-Commerce Last-Mile Delivery Systems},
  author={Pahwa, Anmol},
  abstract={Rapid growth of Q-commerce has produced a dense network of small last-mile delivery facilities (“dark stores”) operating under strict time and distance constraints. Unlike conventional logistics systems, Q-commerce facilities serve compact, highly time-sensitive urban catchments, where even small changes in facility location can significantly alter service coverage, overlap, and operational efficiency. However, existing location-planning approaches largely assume highly regular service regions, typically circular catchments, which do not adequately capture how the shape, structure, and fragmentation of service catchments emerge in dense urban environments. This study aims to develop a spatial modelling framework to analyse how service catchment geometry impacts the configuration (number and location) of Q-commerce dark stores. Instead of committing to one idealised geometry, the framework will test a small set of shape families that span the main mechanisms by which real catchments emerge: (i) distance-limited regions (as a baseline), (ii) tessellating, repeatable partitions that approximate dense facility layouts (grid- or honeycomb-like),  (iii) proximity-based partitions (Voronoi-type) that arise naturally when customers choose the nearest facility and when facilities are repositioned toward the centre of their served region,  and (iv) non-periodic partitions (aperiodic tiling) with “irregular but structured” layouts. These families cover both Euclidean and Rectilinear travel environments and allow the model to represent elongation, fragmentation, and boundary effects without over-specifying a single polygon template. The framework will incorporate constrained or truncated regions with administrative boundaries, barriers, or corridor-like service structures, while remaining consistent with key urban planning constraints. Building on these ideas, the study will quantify how catchment geometry influences overlap, coverage gaps, effective travel distances, and the robustness of promised delivery times. An optimisation layer will generate candidate facility configurations, while a multi-criteria decision module will prioritise configurations that balance operational efficiency and service reliability against city-planning constraints (land-use compatibility, residential exposure, and neighbourhood accessibility). The expected outcome is a transferable decision-support framework linking catchment geometry, location optimisation, and urban planning considerations for regulating Q-commerce last-mile systems in dense cities.},
  institution={Jul 2027},
  year={2027}
}

