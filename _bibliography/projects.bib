@techreport{pahwa2026assessing,
  abbr={PhD},
  title={Assessing Wider Economic Benefits of Transportation Infrastructure Investments (WEB of TransIT)},
  author={Pahwa, Anmol},
  abstract={India’s growing economy and consumption demand are placing increasing pressure on its freight system, which remains heavily dependent on long-haul trucking. While road freight is central to economic growth, it also increases crude oil dependence, greenhouse gas emissions, and local air pollution. Although zero-emission freight technologies offer long-term mitigation potential, their adoption is constrained by technological, infrastructural, and economic barriers. In this context, India’s emerging Dedicated Freight Corridor (DFC) network offers a strategic opportunity to shift freight from road to rail, reduce logistics costs, improve supply-chain reliability, and support sustainable growth. Beyond these direct benefits, freight rail infrastructure can generate wider economic benefits through productivity gains, improved interregional trade linkages, changes in commodity prices, factor returns, household income, tax revenues, public expenditure, and investment decisions. This study aims to estimate the Wider Economic Benefits (WEB) of Transportation Infrastructure (TRANSIT) in India by assessing how the proposed DFC network affects regional household income, factor returns, and fiscal outcomes through changes in logistics costs. It will further develop an optimal DFC network design that maximizes national welfare under infrastructure and fiscal constraints, and compare its aggregate and distributional impacts with the proposed network. Methodologically, the study will develop a nationwide Computable General Equilibrium model incorporating sectoral input-output relationships, commodity consumption behavior, and domestic trade margins to inform strategic freight infrastructure planning in India.},
  institution={Jul 2026},
  year={2026}
}

@techreport{pahwa2026arriving,
  abbr={PhD},
  title={Arriving within Time and Energy Budget: A Dynamic Routing Framework for Electric Vehicles in Stochastic Networks},
  author={Pahwa, Anmol},
  abstract={The transportation sector is one of the most resource intensive industry, contributing 30% to global energy consumption (REN Secretariat, 2024) thereby reinforcing continued fossil fuel dependence, and 23% to global greenhouse gas emissions (Shukla et al., 2022) thus accelerating climate change. Further, it accounts for a significant share of criteria pollutant emissions – worsening local community health (World Health Organization, 2021). To this end, electric vehicles present a sustainable pathway towards reducing these negative externalities, however, their wide scale adoption is hindered by several practical constraints, with range anxiety posing one of the most significant barriers (Pevec et al., 2019). These challenges are exacerbated by prevailing navigation (route planning) systems. Designed predominantly for internal combustion engine vehicles, conventional routing frameworks optimize for travel time under deterministic assumptions. Consequently, they may propose routes that are energy-infeasible, leading to an electric vehicle getting stranded (Artmeier et al., 2010) – a risk further amplified in stochastic environments where fluctuations in network conditions can significantly undermine route feasibility (Bruni et al., 2020). Therefore, to ensure reliable mobility, this study aims to develop a dynamic (adaptive) routing framework for electric vehicles within stochastic (uncertain) network conditions, incorporating characteristics of the electric powertrain and associated charging infrastructure. To do so, this work proposes Time-Energy Stochastic in-Budget Arrival (TE-SIBA) problem – a finite-horizon Markov Decision Process grounded in the Bellman principle of optimality. To implement this routing framework, the study proposes recursive dynamic programming solution, rendering state-dependent routing policies that maximize the probability of arrival at the destination within prescribed time-energy budgets. Finally, this work will prototype an intelligent navigation system, embedding the TE-SIBA routing framework. With these contributions, this work aims to advance route planning of electric vehicles to help alleviate range anxiety and improve user confidence, thereby supporting broader adoption of electric mobility. Further, this work will form a deployable foundation for next generation of electric vehicle navigation platforms, supporting broader adoption of an economically viable, environmentally efficient, and socially equitable electric mobility. In doing so, the proposed work supports the long-term transition towards sustainable transportation, thus addressing fossil fuel dependence, global climate change, and air-quality impacts of the transportation sector.},
  institution={Jul 2026},
  year={2026}
}

@techreport{palle2025modelling,
  abbr={BTech},
  title={Modelling energy consumption of Unmanned Aerival Vehicles (UAVs) for last-mile delivery},
  author={Palle, Preetham and Pahwa, Anmol},
  abstract={Unmanned Aerial Vehicles (UAVs), commonly known as drones, are emerging as a transformative technology in transportation and logistics. In India, the growth of Drone-as-a-Service (DaaS) platforms across sectors such as logistics, healthcare, and agriculture highlights the increasing operational maturity of UAV systems. Drones offer significant advantages for delivery applications due to their high speeds and ability to bypass ground congestion, thereby reducing delivery times. However, their deployment is constrained by limited payload capacity, high energy requirements at elevated speeds, and strong sensitivity to environmental conditions such as wind and precipitation. This study focuses on the application of UAVs in last-mile delivery, the final stage of the supply chain connecting distribution hubs to end customers. Drone-based delivery systems can operate through multiple configurations, including direct warehouse-to-customer delivery, hybrid truck-drone operations, and larger multi-parcel UAV systems. Existing literature presents mixed conclusions regarding the energy efficiency of drones relative to electric and conventional ground vehicles, largely due to limitations in current modelling approaches. Studies employing detailed UAV energy models often oversimplify logistics operations, while those incorporating realistic delivery systems frequently rely on simplified energy estimations based primarily on travel distance. To address this gap, this study proposes a mesoscopic modelling framework that integrates detailed UAV energy consumption models with realistic representations of last-mile delivery operations. The framework enables a more comprehensive evaluation of drone efficiency, operational feasibility, and sustainability within urban logistics systems.},
  institution={Oct 2025},
  year={2025}
}
@techreport{ramawtar2025exploring,
  abbr={BTech},
  title={Exploring Anthropological, Meteorological, and Temporal Determinants of Air Quality},
  author={Ramawtar Yadav, Om and Pahwa, Anmol},
  abstract={Air pollution has emerged as one of the most severe environmental and public health crises facing the world. India, bears an extraordinary burden with the entire population of 1.4 billion people living in areas with PM2.5 (Particulate Matter with a diameter of 2.5 micrometers or less) concentrations above that recommended by the WHO guidelines (exceeding the 5 μg/m3 annual mean) and 81.9% of the people lived in areas above the Indian National Ambient Air Quality Standards (Annual mean PM2·5 not exceeding 40 μg/m3). Air pollution increases the chances of heart issues, skin infections, eye diseases, throat infections, lung cancer, asthma, bronchitis diseases, etc., Long-term exposure of air pollutions may increase the chances of premature mortalities. Children might face development issues which includes impaired lung function and cognitive developments. Pregnant women might face issues in their pregnancy journey which includes low birth weight, premature births, etc. Air pollution also introduces serious impact on the economy, a report from Dalberg Advisors (Berg, n.d.) calculated the total cost of weak environmental regulations and poor emissions practices: USD $95 billion every year, or 40% of the cost of tackling the Covid-19 pandemic in the country - year after year. Per their research, the costs of poor air quality manifest in six ways: lower labor productivity, lower consumer footfall, premature mortality, lower asset productivity, increased health expenses and welfare losses. At the onset of the industrial revolution fossil fuels like coal and petroleum were deemed as the major sources of energy. Humans widely used them to meet the needs of the modern life and developed increasingly robust ways to drill more fossil fuels from the earth’s crust. The combustion of said fuels numerous gases like Carbon Dioxide (CO2), Sulfur Dioxide (SO2), etc., emerge. These emissions contribute to a host of other environmental problems like acid rain, act as greenhouse gases. Thus, the need to measure the quality of air emerged; to communicate the level of pollution in a given area and assess the impact it could have on public health, national economy and global sustenance. Given the rising levels of air pollution levels and policy directive implications, AQI prediction has been an ongoing research topic with several papers authored that utilise statistical and machine learning models to forecast future AQI values for a variety of geographies. This work attempts to use various machine learning models to predict AQI for Indian cities, being trained on various parameters for each city of selected cities i.e., Delhi, Mumbai, Chennai, Kolkata, Bhopal, and Guwahati were chosen to represent all major geographic and climatic zones of India.},
  institution={Jun 2025},
  year={2025}
}

@techreport{vidhyashankar2025simulating,
  abbr={BTech},
  title={Simulating Daily Urban Mobility in India: Unravelling the travel patterns},
  author={Vidhyashankar, Arvind and Pahwa, Anmol},
  abstract={Travel is an induced demand, characterised by individual’s economic and lifestyle choices. As these travel patterns evolve, urban and transportation planning must adapt to meet these changes. Understanding and forecasting travel demand is crucial for effective infrastructure development and policy planning, ensuring that transportation systems align with the needs of the population. Thus, to identify typical travel demand patterns, this study will develop an activity-based model and simulate a day in the life of Indians. In particular, the authors will utilise the 2019 Indian Time Use Survey to model an individual’s daily activity plan as a Markov Process and consequently simulate transitions between daily activities such as work, education, leisure, domestic chores, etc., across different times of the day, while also accounting for individual, communal, and regional factors. In doing so, this study will inform stakeholders for better urban and transportation planning tailored to unique demographic and economic landscapes of different Indian cities.},
  institution={Oct 2025},
  year={2025}
}

